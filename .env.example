# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://canopy_sight:changeme@localhost:5432/canopy_sight"
DIRECT_URL="postgresql://canopy_sight:changeme@localhost:5432/canopy_sight"

# ── Auth (NextAuth) ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Auth (Google OAuth) ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
CLERK_SECRET_KEY="sk_test_your-clerk-secret-key"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your-clerk-publishable-key"

# ── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
OPENAI_API_KEY="sk-your-openai-key"

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── Redis (local / BullMQ) ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Cloudflare R2 Storage ────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="canopy-sight-media"

# ── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN="https://your-sentry-dsn@sentry.io/123"
BETTERSTACK_API_KEY="your-betterstack-api-key"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
