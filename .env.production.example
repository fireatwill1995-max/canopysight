# ══════════════════════════════════════════════════════════════════════════════
# Canopy Sight — Production Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file and set values via your secret manager (Doppler, Fly secrets,
# GitHub Actions secrets). NEVER commit real values to version control.
#
# On Fly.io, set secrets with:
#   fly secrets set KEY=value -a canopy-sight-api
#
# Legend:
#   [REQUIRED]    — must be set or the service will not start
#   [RECOMMENDED] — strongly recommended for production
#   [OPTIONAL]    — enables additional features
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string (Neon, Supabase, or self-hosted)
# Use connection pooling URL for the app, direct URL for migrations
DATABASE_URL="postgresql://user:password@host:5432/canopy_sight?sslmode=require"

# [REQUIRED for Prisma] Direct connection (bypasses PgBouncer)
DIRECT_URL="postgresql://user:password@host:5432/canopy_sight?sslmode=require"

# ── Authentication (Clerk) ───────────────────────────────────────────────────
# [REQUIRED] Clerk production secret key (starts with sk_live_)
CLERK_SECRET_KEY="sk_live_..."

# [REQUIRED] Clerk publishable key for the web frontend
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."

# ── Server ───────────────────────────────────────────────────────────────────
# [SET IN fly.toml] These are configured in the Fly deployment config
# NODE_ENV="production"
# PORT=8080
# HOST="0.0.0.0"

# ── CORS / Networking ───────────────────────────────────────────────────────
# [REQUIRED] URL of the web frontend (used for CORS origin)
FRONTEND_URL="https://canopy-sight-web.fly.dev"

# [OPTIONAL] Additional allowed CORS origins (comma-separated)
ALLOWED_ORIGINS="https://canopy-sight-web.fly.dev"

# [REQUIRED for web] API URL for tRPC client and health proxy
NEXT_PUBLIC_API_URL="https://canopy-sight-api.fly.dev"

# ── Redis / Caching ─────────────────────────────────────────────────────────
# [RECOMMENDED] Upstash Redis for caching, rate limiting, and queues
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# [OPTIONAL] Standard Redis URL (if using self-hosted Redis instead of Upstash)
# REDIS_URL="redis://user:password@host:6379"

# ── Cloudflare R2 Storage ───────────────────────────────────────────────────
# [REQUIRED] Object storage for video clips, images, and media
CLOUDFLARE_R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="canopy-sight-media"

# ── AI / LLM Services ───────────────────────────────────────────────────────
# [OPTIONAL] Anthropic API key for Claude-powered analysis
ANTHROPIC_API_KEY="sk-ant-..."

# [OPTIONAL] OpenAI API key for embeddings and vector search
OPENAI_API_KEY="sk-..."

# ── Observability ────────────────────────────────────────────────────────────
# [RECOMMENDED] Sentry DSN for error tracking
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# [OPTIONAL] BetterStack API key for uptime and log management
BETTERSTACK_API_KEY="your-betterstack-api-key"

# ── Health Check Security ───────────────────────────────────────────────────
# [OPTIONAL] Secret key to protect /health/detailed endpoint
# If set, requests to /health/detailed must include header: x-health-key: <value>
# HEALTH_CHECK_KEY="your-random-secret-here"

# ── Rate Limiting ────────────────────────────────────────────────────────────
# [OPTIONAL] Override default rate limits (200 requests per 60s per org)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=200

# ── Secret Management ───────────────────────────────────────────────────────
# For production, consider using Doppler (https://doppler.com) to manage
# secrets centrally. Doppler integrates with Fly.io:
#
#   doppler secrets download --no-file --format env | fly secrets import -a canopy-sight-api
#
# This avoids storing secrets in CI/CD pipelines and provides audit trails.
