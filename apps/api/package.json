{
  "name": "@canopy-sight/api",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"var p=require('path'); require('child_process').execSync('npx tsc -p apps/api', { cwd: p.resolve(process.cwd(), p.join('..','..')), stdio: 'inherit' })\"",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@canopy-sight/ai": "*",
    "@canopy-sight/auth": "*",
    "@canopy-sight/database": "*",
    "@canopy-sight/validators": "*",
    "@clerk/clerk-sdk-node": "^5.0.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@canopy-sight/utils": "*",
    "@sentry/node": "^7.91.0",
    "@trpc/server": "^10.45.0",
    "bullmq": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "openapi-types": "^12.1.3",
    "socket.io": "^4.7.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@canopy-sight/config": "*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
